# ─────────────────────────────────────────────────────────────
# 3PM Drive — environment template
# Copy to `.env.local` for dev, or set these in the Render dashboard for prod.
# NO real secrets in this file — it is committed to the repo.
# ─────────────────────────────────────────────────────────────

# ── 3PM Auth / SSO ──
# dev: http://localhost:3001   prod: https://accounts.3pm.app
IDP_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
# 3PM Data API key (needs subscriptions:read). Issue Drive its OWN key for prod.
DATA_API_KEY=

# ── App / session ──
# dev: http://localhost:3000   prod: https://drive.3pm.app
NEXT_PUBLIC_APP_URL=
SESSION_MAX_AGE=86400

# ── MongoDB ──
# prod: a MongoDB Atlas SRV URI. getDb() selects the DB via MONGODB_DB_NAME
# (the DB segment in the URI is ignored), so set the name explicitly.
MONGODB_URI=
MONGODB_DB_NAME=drive

# ── Form Builder embed (inspections) ──
# Session-based, per-tenant (construction-portal pattern): each tenant is
# onboarded to its own Form Builder organization via the app secret; the
# per-tenant embed token is stored in the DB. No token env vars.
NEXT_PUBLIC_FORM_BUILDER_URL=
FORM_BUILDER_APP_ID=
FORM_BUILDER_APP_SECRET=
# Only for POST /api/forms/sync-submissions (reads Form Builder's DB directly):
# FORM_BUILDER_MONGODB_URI=
# FORM_BUILDER_DB_NAME=

# ── Widget Builder embed (maps / tracker) ──
NEXT_PUBLIC_WIDGET_BUILDER_URL=
WIDGET_BUILDER_APP_ID=
WIDGET_BUILDER_APP_SECRET=

# ── Shared secrets ──
WEBHOOK_SHARED_SECRET=   # authenticates Form Builder → Drive webhook calls
CRON_SECRET=             # protects GET /api/cron/* scan endpoints

# ── Email — tried in order: Resend → SendGrid → Gmail ──
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@3pm.app    # must be a domain VERIFIED in Resend
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@3pm.app
# GMAIL_USER=
# GMAIL_APP_PASSWORD=

# ── AI (Buddy) — OpenRouter ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── AWS S3 (file/document uploads). REQUIRED in prod: Render's disk is
#    ephemeral, so the local-disk fallback would lose uploaded files. ──
AWS_S3_BUCKET_NAME=3pm-drive-storage
AWS_S3_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Command connection (blank COMMAND_BASE_URL = standalone mode) ──
COMMAND_BASE_URL=
COMMAND_SERVICE_CLIENT_ID=       # must match ASSET_MANAGER_CLIENT_ID/SECRET in Command
COMMAND_SERVICE_CLIENT_SECRET=
COMMAND_APP_CLIENT_ID=           # Command's 3PM Auth clientId (entitlement check)

# ── IoT Hub (telemetry sync) — use a dedicated service account in prod ──
IOT_HUB_API_BASE_URL=https://3pmcloud-iothub-prod.azurewebsites.net/api/v1
IOT_HUB_USERNAME=
IOT_HUB_PASSWORD=

# ── CarJam (NZ vehicle lookup / asset auto-fill) ──
CARJAM_API_BASE_URL=https://www.carjam.co.nz
CARJAM_API_KEY=
# "1" returns canned mock data (no key needed). Set "0" for real lookups in prod.
CARJAM_MOCK=0
